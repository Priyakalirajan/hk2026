{
  "expo": {
    "name": "OBL SwiftOnboard",
    "slug": "obl-swiftonboard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0d14"
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "OBL SwiftOnboard needs camera access to scan KYC documents." }],
      ["expo-notifications", { "color": "#f4a034" }],
      "expo-secure-store"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0d14"
      },
      "package": "com.orientbell.swiftonboard",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "ios": {
      "bundleIdentifier": "com.orientbell.swiftonboard",
      "supportsTablet": true
    },
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
